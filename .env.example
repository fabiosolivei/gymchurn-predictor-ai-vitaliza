# VITE_API_URL: URL do backend FastAPI (Render) que serve o modelo XGBoost real + SHAP.
# Dev local: http://localhost:8000
VITE_API_URL="http://localhost:8000"

# VITE_BASE: base path para GitHub Pages, ex /gymchurn-predictor-ai-vitaliza/. Em dev deixe /.
VITE_BASE="/"

# GEMINI_API_KEY: legado. A predição NÃO usa mais Gemini (vem do backend). Pode deixar vazio.
GEMINI_API_KEY=""
